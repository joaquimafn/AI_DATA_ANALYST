# Database
POSTGRES_USER=ai_analyst
POSTGRES_PASSWORD=ai_analyst_secret
POSTGRES_DB=ai_analyst_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ai_analyst:ai_analyst_secret@localhost:5432/ai_analyst_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# LLM Providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Application
APP_ENV=development
LOG_LEVEL=INFO
